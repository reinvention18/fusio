# Mission Control / Fusio — environment variables (all optional)
#
# Copy this file to .env.local and fill in what you want to override.
# Most users don't need ANY of these — defaults work for single-machine setups.

# ─── Anthropic API ────────────────────────────────────────────────────
# The chat agent's primary provider. Required if you want chat to work.
# Set in the Credentials panel inside MC (Settings → Credentials) or here.
ANTHROPIC_API_KEY=

# ─── OpenAI / Codex (optional) ────────────────────────────────────────
# Used for scrutiny in missions and Codex consult in teams.
OPENAI_API_KEY=

# ─── Resend (optional) ────────────────────────────────────────────────
# Used by api/contact and any notification flows you wire in.
RESEND_API_KEY=

# ─── Multi-machine bridge (optional) ──────────────────────────────────
# If you run MC on more than one machine and want to share a notepad,
# point the non-canonical machines at the canonical one:
# MC_NOTEPAD_PEER=http://10.0.0.5:3001

# ─── HTTPS proxy / PWA (optional) ─────────────────────────────────────
# See header comment in https-proxy.js for setup.
# MC_HTTPS_PORT=3443
# MC_NEXT_PORT=3001
# MC_CERT_PATH=certs/tls.crt
# MC_KEY_PATH=certs/tls.key
# MC_PWA_URL=https://mc.example.local:3443

# ─── Next dev cross-origin allowlist (optional) ───────────────────────
# Comma-separated origins. Only needed if you reach the dev server from
# a different host (Tailscale hostname, LAN IP, mobile PWA, etc.).
# MC_ALLOWED_DEV_ORIGINS=https://my-box.tail123.ts.net,https://192.168.1.50:3443

# ─── PM2 / dev runtime (optional) ─────────────────────────────────────
# These are typically set in ecosystem.config.js. Override here if needed.
# NODE_ENV=development
# PORT=3001
# NODE_OPTIONS=--max-old-space-size=8192

# ─── Git author for chat-driven commits (optional) ────────────────────
# If MC commits via the chat agent, these set the author.
# MC_GIT_USER_NAME=Your Name
# MC_GIT_USER_EMAIL=you@example.com
